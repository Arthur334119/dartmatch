{
  "expo": {
    "name": "Kneipenfinder",
    "slug": "kneipenfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kneipenfinder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.arthur33.kneipenfinder",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Wir brauchen Zugriff auf deine Fotos, damit du dein Profilbild auswählen kannst.",
        "NSCameraUsageDescription": "Wir brauchen Zugriff auf deine Kamera, damit du ein Profilbild aufnehmen kannst.",
        "NSLocationWhenInUseUsageDescription": "Wir nutzen deinen Standort, um Kneipen in deiner Nähe zu finden."
      }
    },
    "android": {
      "package": "de.arthur33.kneipenfinder",
      "adaptiveIcon": {
        "backgroundColor": "#E8852B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FBF7F2",
          "dark": {
            "backgroundColor": "#15110D"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wir brauchen Zugriff auf deine Fotos, damit du dein Profilbild auswählen kannst.",
          "cameraPermission": "Wir brauchen Zugriff auf deine Kamera, damit du ein Profilbild aufnehmen kannst."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Wir nutzen deinen Standort, um Kneipen in deiner Nähe zu finden."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
